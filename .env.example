# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Role IDs for permissions (comma-separated, optional)
# Users with these roles can use giveaway commands
ALLOWED_ROLE_IDS=1234567890123456789,9876543210987654321

# Users with these roles can use moderation commands (ban, kick, timeout, etc.)
MODERATOR_ROLE_IDS=1234567890123456789

# Users with these roles can use admin commands (announce, command toggle, etc.)
ADMIN_ROLE_IDS=1234567890123456789

# Note: ADMIN_ROLE_IDS have all permissions (moderation + admin)
# Leave empty to allow everyone (not recommended)
