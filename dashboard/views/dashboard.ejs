<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Axion Dashboard</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <main class="container">
    <section class="hero">
      <div class="brand"><span class="dot"></span> AXION</div>
      <h1>Welcome, <%= user.username %></h1>
      <p>Pick a server to open Axion settings.</p>
      <div class="actions">
        <a class="btn secondary" href="/logout">Logout</a>
      </div>
    </section>

    <% if (typeof noAuthMode !== 'undefined' && noAuthMode) { %>
      <div class="card warning">⚠️ NO_AUTH mode enabled. Anyone with URL access can manage settings.</div>
    <% } %>

    <section class="card">
      <h2>Your Servers</h2>
      <p class="muted">Only servers you can manage are shown.</p>
    </section>
    <div id="guilds">Loading...</div>
  </main>
  <script src="/js/dashboard.js"></script>
</body>
</html>
