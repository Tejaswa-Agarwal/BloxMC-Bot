<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Axion Dashboard</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <main class="container">
    <section class="hero">
      <div class="brand"><span class="dot"></span> AXION</div>
      <h1>Axion Control Center</h1>
      <p>Clean, fast server management for moderation, automod, tickets, and more.</p>
      <div class="actions">
        <% if (user) { %>
          <a class="btn" href="/dashboard">Open Dashboard</a>
          <a class="btn secondary" href="/logout">Logout</a>
        <% } else { %>
          <a class="btn" href="/login">Login with Discord</a>
        <% } %>
      </div>
    </section>

    <section class="card">
      <h2>Quick Setup</h2>
      <p class="muted">Runtime environment for dashboard + bot:</p>
      <pre><code>ENABLE_DASHBOARD=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=25575

# Recommended with domain:
DISCORD_CLIENT_ID=...
DISCORD_CLIENT_SECRET=...
DASHBOARD_CALLBACK=https://your-domain.com/callback

# Optional local bootstrap (disable after OAuth setup):
DASHBOARD_NO_AUTH=true</code></pre>
    </section>
  </main>
</body>
</html>
